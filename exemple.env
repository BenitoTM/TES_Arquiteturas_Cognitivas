PORTKEY_MODEL=z-ai/glm-4.5-air:free
PORTKEY_BASE_URL=https://api.portkey.ai/v1
SYSTEM_PROMPT=You are a helpful assistant.
USER_MESSAGE=Hello chatgpt, how are you?
LANGGRAPH_THREAD_ID=default
REACT_USER_MESSAGE=Pesquise os 3 países com maior PIB da América do Sul e compare a média do PIB per capita deles com a média mundial.
REACT_MAX_STEPS=10
COALA_MEMORY_DIR=data/coala_memory
CHATBOT_LANGGRAPH_MERMAID=artifacts/graphs/chatbot_graph.mmd
